# backups/restic.env.example
# Copy this file to backups/restic.env and fill in your credentials.
# setup-backups.sh will install this to /etc/restic/restic.env (root-only).
# Do NOT commit restic.env to version control.

# ── Repository location ───────────────────────────────────────────────────────
# Local path example (on same disk — good for quick restore, but backup to
# a separate drive or cloud for real protection):
#   RESTIC_REPOSITORY=/mnt/backup/minecraft
#
# SFTP (remote server) example:
#   RESTIC_REPOSITORY=sftp:user@backupserver:/backups/minecraft
#
# B2 (Backblaze) example:
#   RESTIC_REPOSITORY=b2:bucketname:/minecraft
#   B2_ACCOUNT_ID=your_account_id
#   B2_ACCOUNT_KEY=your_application_key
#
# S3-compatible example:
#   RESTIC_REPOSITORY=s3:s3.amazonaws.com/bucketname
#   AWS_ACCESS_KEY_ID=your_access_key
#   AWS_SECRET_ACCESS_KEY=your_secret_key
RESTIC_REPOSITORY=CHANGE_ME

# ── Repository encryption password ───────────────────────────────────────────
# All restic repositories are encrypted. Pick a strong password and store it
# somewhere safe (password manager). If you lose this password, you lose access
# to your backups.
RESTIC_PASSWORD=CHANGE_ME

# ── Retention policy (adjust as needed) ──────────────────────────────────────
KEEP_HOURLY=24
KEEP_DAILY=7
KEEP_WEEKLY=12
KEEP_MONTHLY=6
KEEP_YEARLY=5

# ── Optional: cloud provider credentials ─────────────────────────────────────
# Uncomment and fill in if using a cloud backend (see examples above).

# Backblaze B2
# B2_ACCOUNT_ID=CHANGE_ME
# B2_ACCOUNT_KEY=CHANGE_ME

# AWS S3 or S3-compatible
# AWS_ACCESS_KEY_ID=CHANGE_ME
# AWS_SECRET_ACCESS_KEY=CHANGE_ME
