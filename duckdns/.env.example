# duckdns/.env.example
# Copy this file to duckdns/.env and fill in your credentials.
# Do NOT commit .env to version control.
#
# Get your token at: https://www.duckdns.org/

# Your DuckDNS subdomain (just the name, not the full hostname)
# Example: if your hostname is myhomemc.duckdns.org, set:
DUCKDNS_SUBDOMAIN=CHANGE_ME

# Your DuckDNS account token (from the DuckDNS dashboard)
DUCKDNS_TOKEN=CHANGE_ME
