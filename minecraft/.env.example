# minecraft/.env.example
# Copy this file to minecraft/.env (or /opt/minecraft/.env) and edit.
# Do NOT commit .env to version control — it may contain secrets.

# ── Required ──────────────────────────────────────────────────────────────────
# You MUST accept the Minecraft EULA: https://aka.ms/MinecraftEULA
EULA=TRUE

# ── Server type and version ───────────────────────────────────────────────────
# TYPE options: PAPER (recommended), SPIGOT, VANILLA, FABRIC, FORGE
TYPE=PAPER

# Minecraft version — LATEST or a specific version like 1.21.4
MC_VERSION=LATEST

# ── Memory ────────────────────────────────────────────────────────────────────
# Heap size passed to the JVM. 4G is good for ~10 players on Paper.
MEMORY=4G

# Docker container hard memory limit (should be ~1 G above MEMORY)
CONTAINER_MEMORY_LIMIT=5g

# ── Server identity ───────────────────────────────────────────────────────────
MOTD=A Paper Minecraft Server
DIFFICULTY=normal
MAX_PLAYERS=10
ONLINE_MODE=true

# ── Performance ───────────────────────────────────────────────────────────────
VIEW_DISTANCE=8
SIMULATION_DISTANCE=6

# ── RCON (admin + safe backup saves) ─────────────────────────────────────────
ENABLE_RCON=true
# IMPORTANT: change this password before exposing the server
RCON_PASSWORD=changeme_rcon_secret

# ── Optional ──────────────────────────────────────────────────────────────────
# Comma-separated list of operator usernames
# OPS=YourUsername

# Whitelist (set ENFORCE_WHITELIST=true to restrict who can join)
# WHITELIST=YourUsername,FriendUsername
# ENFORCE_WHITELIST=false

# World seed (leave blank for a random seed)
# LEVEL_SEED=

# ── Bedrock Edition Crossplay (Geyser + Floodgate) ────────────────────────────
# Allows Bedrock players (Xbox, Switch, mobile, Windows 10/11) to join this Java server.
# Bedrock players connect via UDP port 19132 (must be forwarded on your router).
# Bedrock players appear with a prefix before their username (default: ".")
#   e.g. a Bedrock player "Steve" shows up in-game as ".Steve"
# To whitelist a Bedrock player, use the prefixed name: WHITELIST=.BedrockPlayer
GEYSER_ENABLED=true
FLOODGATE_ENABLED=true
